# Notifications — set NOTIFICATION_PROVIDER=resend + RESEND_API_KEY + STAFF_NOTIFICATION_EMAIL
# to enable real email delivery for consultation requests. "stub" (default) just
# logs to the server console — safe for local dev, NOT safe for production.
NOTIFICATION_PROVIDER="stub"
# NOTIFICATION_PROVIDER=resend
# RESEND_API_KEY="re_..."
NOTIFICATION_FROM_EMAIL="noreply@atlasenrollment.com"
# STAFF_NOTIFICATION_EMAIL="hello@atlasenrollment.com"
